local Http = game:GetService("HttpService")

local HUB_URL = (_G.list and _G.list ~= "" and _G.list)
    or "https://raw.githubusercontent.com/leo0ntop0-alt/rolbox/refs/heads/main/myscript.lua"

local scripts = {}
local favs = {}
local loaded = false

local placeId = tostring(game.PlaceId)
local matches = {}
local uiRefresh = 0

local favFile = "Matcha_Favs_V2.json"

--// Favorites

local function saveFavs()
    local success, data = pcall(function()
        return Http:JSONEncode(favs)
    end)

    if success then
        writefile(favFile, data)
    end
end

local function loadFavs()
    if not isfile(favFile) then
        favs = {}
        return
    end

    local success, data = pcall(function()
        return Http:JSONDecode(readfile(favFile))
    end)

    favs = (success and type(data) == "table") and data or {}
end

local function isFav(name)
    for _, v in pairs(favs) do
        if v.name == name then
            return true
        end
    end
end

--// Matching

local function getIds(entry)
    local id = entry.placeId or entry.gameId
    if not id then return {} end

    return type(id) == "table" and id or {id}
end

local function updateMatches()
    matches = {}
    placeId = tostring(game.PlaceId)

    for _, sc in pairs(scripts) do
        for _, id in pairs(getIds(sc)) do
            if tostring(id) == placeId then
                table.insert(matches, sc)
                break
            end
        end
    end
end

--// Sync

local function sync()
    loaded = false
    loadFavs()

    local ok, res = pcall(game.HttpGet, game, HUB_URL)
    if not ok or not res or res == "" then
        loaded = true
        return
    end

    -- quick fix for numeric ids breaking JSON
    res = res:gsub('("placeId"%s*:%s*)(%d+)', '%1"%2"')
    res = res:gsub('("gameId"%s*:%s*)(%d+)', '%1"%2"')

    local success, data = pcall(function()
        return Http:JSONDecode(res)
    end)

    if success and type(data) == "table" then
        scripts = data
        updateMatches()
    end

    loaded = true
end

task.spawn(sync)

--// Utils

local function shortName(name, fav)
    name = tostring(name or "Unknown")

    if #name > 28 then
        name = name:sub(1, 25) .. "..."
    end

    return fav and ("⭐ " .. name) or name
end

local function run(code)
    if not code or code == "" then
        warn("No code??")
        return
    end

    local fn = loadstring(code)
    if not fn then
        warn("Failed to load script")
        return
    end

    task.spawn(fn)
end

--// UI

UI.AddTab("Script Library V2", function(tab)

    if not loaded then
        tab:Section("Status", "Left"):Text("Loading scripts...")
        return
    end

    local nav = tab:Section("", "Left", {"Explorer", "Favorites"})

    if nav.page == 0 then
        local search = tab:Section("Search", "Left")
        search:InputText("q", "Search...", "")

        local q = tostring(UI.GetValue("q") or ""):lower()

        local list = {}
        for _, sc in pairs(scripts) do
            if q == "" or (sc.name and sc.name:lower():find(q, 1, true)) then
                table.insert(list, sc)
            end
        end

        local names = {}
        for _, sc in pairs(list) do
            table.insert(names, shortName(sc.name, isFav(sc.name)))
        end

        if #names == 0 then
            names = {"Nothing found"}
        end

        local key = "list_" .. q .. uiRefresh
        tab:Section("Scripts (" .. #names .. ")", "Left")
            :Combo(key, "Pick Script", names, 0)

        local idx = UI.GetValue(key)
        local picked = (idx and list[idx + 1]) or nil

        -- Game match section
        local auto = tab:Section("Auto Detect", "Right")
        auto:Text("Game ID: " .. placeId)

        if #matches > 0 then
            local matchNames = {}

            for _, m in pairs(matches) do
                table.insert(matchNames, shortName(m.name, isFav(m.name)))
            end

            local mKey = "match_" .. placeId .. uiRefresh
            auto:Combo(mKey, "Matches", matchNames, 0)

            local mIdx = UI.GetValue(mKey)
            local chosen = (mIdx and matches[mIdx + 1]) or nil

            if chosen then
                auto:Button("Run Match", 200, 36, function()
                    run(chosen.script)
                end)
            end
        else
            auto:Text("No scripts for this game")
            auto:Button("Refresh", 140, 30, function()
                task.spawn(sync)
            end)
        end

        -- Selected script controls
        if picked then
            local sec = tab:Section("Selected", "Right")

            sec:Text("Name: " .. tostring(picked.name))
            sec:Text("By: " .. tostring(picked.uploader or picked.author or "Unknown"))

            local favIndex
            for i, v in pairs(favs) do
                if v.name == picked.name then
                    favIndex = i
                    break
                end
            end

            sec:Button(favIndex and "Unfavorite" or "Favorite", 150, 34, function()
                if favIndex then
                    table.remove(favs, favIndex)
                else
                    table.insert(favs, {
                        name = picked.name,
                        author = picked.uploader or picked.author,
                        script = picked.script
                    })
                end

                saveFavs()
                uiRefresh += 1
            end)

            sec:Button("Run Script             ", 199, 40, function()
                run(picked.script)
            end)
        end

    else
        local sec = tab:Section("Favorites (" .. #favs .. ")", "Left")

        if #favs == 0 then
            sec:Text("No favorites yet")
            return
        end

        local names = {}
        for _, f in pairs(favs) do
            table.insert(names, shortName(f.name, true))
        end

        local key = "fav_" .. uiRefresh
        sec:Combo(key, "Select", names, 0)

        local idx = UI.GetValue(key)
        local f = (idx and favs[idx + 1]) or nil

        if f then
            local ctrl = tab:Section("Options", "Right")

            ctrl:Text("Name: " .. f.name)
            ctrl:Text("By: " .. (f.author or "Unknown"))

            ctrl:Button("Remove", 150, 34, function()
                table.remove(favs, idx + 1)
                saveFavs()
                uiRefresh += 1
            end)

            ctrl:Button("Run Script          ", 190, 40, function()
                run(f.script)
            end)
        end
    end
end)
