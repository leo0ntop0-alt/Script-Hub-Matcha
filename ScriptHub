local HttpService = game:GetService("HttpService")

local HUB_URL = type(_G.list) == "string" and _G.list ~= "" and _G.list
	or "https://raw.githubusercontent.com/leo0ntop0-alt/rolbox/refs/heads/main/myscript.lua"

local scripts = {}
local favorites = {}
local ready = false
local currentId = tostring(game.PlaceId)
local detectedMatches = {}
local forcedReset = 0
local favFile = "Matcha_Favs_V2.json"

local function saveToDisk()
	local ok, content = pcall(function()
		return HttpService:JSONEncode(favorites)
	end)

	if ok then
		writefile(favFile, content)
	end
end

local function loadFromDisk()
	if isfile(favFile) then
		local ok, content = pcall(function()
			return HttpService:JSONDecode(readfile(favFile))
		end)

		if ok and type(content) == "table" then
			favorites = content
			return
		end
	end

	favorites = {}
end

local function isFavorited(scriptName)
	for _, f in ipairs(favorites) do
		if tostring(f.name) == tostring(scriptName) then
			return true
		end
	end
	return false
end

local function getPlaceIds(entry)
	local pid = entry.placeId or entry.gameId

	if pid == nil or tostring(pid) == "0" then
		return {}
	end

	if type(pid) == "table" then
		return pid
	end

	return { pid }
end

local function runGameDetection()
	detectedMatches = {}
	currentId = tostring(game.PlaceId)

	for _, s in ipairs(scripts) do
		for _, pid in ipairs(getPlaceIds(s)) do
			if tostring(pid) == currentId then
				table.insert(detectedMatches, s)
				break
			end
		end
	end
end

local function syncDatabase()
	ready = false
	loadFromDisk()

	local ok, rawText = pcall(game.HttpGet, game, HUB_URL)
	if ok and rawText and rawText ~= "" then
		local protectedJson = rawText:gsub('("placeId"%s*:%s*)(%d+)', '%1"%2"')
		protectedJson = protectedJson:gsub('("gameId"%s*:%s*)(%d+)', '%1"%2"')

		local ok2, data = pcall(function()
			return HttpService:JSONDecode(protectedJson)
		end)

		if ok2 and type(data) == "table" then
			scripts = data
			runGameDetection()
			ready = true
			return true
		end
	end

	ready = true
	return false
end

task.spawn(syncDatabase)

local function comboWrap(name, starred)
	local limit = 28
	local str = tostring(name or "Unknown")
	local truncated = (#str <= limit and str or str:sub(1, limit - 3) .. "...")
	return starred and ("⭐ " .. truncated) or truncated
end

local function runScript(source)
	if type(source) ~= "string" or source == "" then
		warn("[ScriptLib] Missing script source.")
		return
	end

	local fn, err = loadstring(source)
	if fn then
		task.spawn(fn)
	else
		warn("[ScriptLib] Load error: " .. tostring(err))
	end
end

UI.AddTab("Script Library V2", function(tab)
	if not ready then
		tab:Section("Status", "Left"):Text("Syncing Cloud...")
		return
	end

	local nav = tab:Section("", "Left", {"Explorer", "Favorites"})

	if nav.page == 0 then
		local searchSec = tab:Section("Search Engine", "Left")
		searchSec:InputText("q", "Filter Scripts...", "")

		local q = tostring(UI.GetValue("q") or ""):lower()
		local filtered = {}

		for _, s in ipairs(scripts) do
			if q == "" or (s.name and tostring(s.name):lower():find(q, 1, true)) then
				table.insert(filtered, s)
			end
		end

		local browseSec = tab:Section("Scripts (" .. #filtered .. ")", "Left")
		local names = {}

		for _, s in ipairs(filtered) do
			table.insert(names, comboWrap(s.name, isFavorited(s.name)))
		end

		if #names == 0 then
			names = {"No results"}
		end

		local comboKey = "list_" .. q .. "_v" .. forcedReset .. "_f" .. #favorites
		browseSec:Combo(comboKey, "Select Script", names, 0)

		local chosenIdx = UI.GetValue(comboKey)
		local chosen = (chosenIdx ~= nil and #filtered > 0) and filtered[chosenIdx + 1] or nil

		local autoSec = tab:Section("Game Detection", "Right")
		autoSec:Text("Current ID: " .. currentId)

		if #detectedMatches > 0 then
			local dNames = {}

			for _, s in ipairs(detectedMatches) do
				table.insert(dNames, comboWrap(s.name, isFavorited(s.name)))
			end

			local detKey = "det_res_" .. currentId .. "_v" .. forcedReset
			autoSec:Combo(detKey, "Matches", dNames, 0)

			local dIdx = UI.GetValue(detKey)
			local dChosen = (dIdx ~= nil and #detectedMatches > 0) and detectedMatches[dIdx + 1] or nil

			if dChosen then
				autoSec:Button("Execute Match", 200, 36, function()
					runScript(dChosen.script)
				end)
			end
		else
			autoSec:Text("No matches for this game.")
			autoSec:Button("Refresh", 140, 30, function()
				task.spawn(syncDatabase)
			end)
		end

		if chosen then
			local controlSec = tab:Section("Execution Panel", "Right")
			controlSec:Text("Selected: " .. tostring(chosen.name or "Unknown"))
			controlSec:Text("Author: " .. tostring(chosen.uploader or chosen.author or "Unknown"))

			local fIdx = nil
			for i, f in ipairs(favorites) do
				if f.name == chosen.name then
					fIdx = i
					break
				end
			end

			controlSec:Button(fIdx and "Remove Favorite" or "Star Favorite", 150, 34, function()
				if fIdx then
					table.remove(favorites, fIdx)
				else
					table.insert(favorites, {
						name = chosen.name,
						author = chosen.uploader or chosen.author or "Unknown",
						script = chosen.script
					})
				end

				saveToDisk()
				forcedReset = forcedReset + 1
			end)

			controlSec:Button("Run Selected Script           ", 199, 40, function()
				runScript(chosen.script)
			end)
		end

	elseif nav.page == 1 then
		local fCount = #favorites
		local favSec = tab:Section("Your Favorites (" .. fCount .. ")", "Left")

		if fCount == 0 then
			favSec:Text("List is empty.")
			return
		end

		local fNames = {}
		for _, f in ipairs(favorites) do
			table.insert(fNames, comboWrap(f.name, true))
		end

		local favComboKey = "fav_list_v" .. forcedReset
		favSec:Combo(favComboKey, "Select Favorite", fNames, 0)

		local fIdx = UI.GetValue(favComboKey)
		local fChosen = (fIdx ~= nil and #favorites > 0) and favorites[fIdx + 1] or nil

		if fChosen then
			local fControl = tab:Section("Favorite Actions", "Right")
			fControl:Text("Selected: " .. tostring(fChosen.name or "Unknown"))
			fControl:Text("Author: " .. tostring(fChosen.author or "Unknown"))

			fControl:Button("Remove Favorite", 150, 34, function()
				if fIdx ~= nil then
					table.remove(favorites, fIdx + 1)
					saveToDisk()
					forcedReset = forcedReset + 1
				end
			end)

			fControl:Button("Run Favorite Script         ", 190, 40, function()
				runScript(fChosen.script)
			end)
		end
	end
end)

notify("Script Library V2 tab was added to your Matcha interface", "Script Library V2", 7)
warn("[ScriptLib] Recommended: Put the Script Library in Matcha auto execute so it stays in your Matcha interface.")
