-- ─────────────────────────────────────────
--  AUDIO & NOTIFY HELPERS
-- ─────────────────────────────────────────
local function playExecuteSound()
    task.spawn(function()
        pcall(function()
            local s = Instance.new("Sound")
            s.SoundId = "rbxassetid://170765130" 
            s.Volume = 1
            s.Parent = game:GetService("SoundService")
            s:Play()
            s.Ended:Wait()
            s:Destroy()
        end)
    end)
end

local function notify(title, text, duration)
    task.spawn(function()
        pcall(function()
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = title,
                Text = text,
                Duration = duration or 3
            })
        end)
    end)
end

local function wrapName(text, maxLen)
    maxLen = maxLen or 28
    if not text then return "—" end
    if #text <= maxLen then return text end
    return text:sub(1, maxLen-3) .. "..."
end

-- ─────────────────────────────────────────
--  FAVORITES SYSTEM
-- ─────────────────────────────────────────
local function loadFavorites()
    local ok, raw = pcall(readfile, FAV_FILE)
    if ok and raw and raw ~= "" then
        local hs = game:GetService("HttpService")
        local ok2, data = pcall(hs.JSONDecode, hs, raw)
        if ok2 and type(data) == "table" then 
            favorites = data 
            return 
        end
    end
    favorites = {}
end

local function saveFavorites()
    local hs = game:GetService("HttpService")
    local ok, encoded = pcall(hs.JSONEncode, hs, favorites)
    if ok then pcall(writefile, FAV_FILE, encoded) end
end

local function isFavorite(name)
    if not name then return false end
    for _, v in ipairs(favorites) do 
        if v == name then return true end 
    end
    return false
end

-- ─────────────────────────────────────────
--  OVERLAY SYSTEM (FIXED NIL NEW ERROR)
-- ─────────────────────────────────────────
local function destroyOverlay()
    for _, obj in ipairs(overlayObjects) do
        pcall(function()
            if obj then
                obj.Visible = false
                obj:Remove()
            end
        end)
    end
    overlayObjects = {}
end

local function buildOverlay(scriptName, uploaderName)
    destroyOverlay()
    if not overlayEnabled then return end

    -- Safety check for Drawing API
    local drawLib = (Drawing or (getgenv and getgenv().Drawing))
    if not drawLib or type(drawLib) ~= "table" or not drawLib.new then return end

    pcall(function()
        local bg = drawLib.new("Square")
        bg.Filled, bg.Color, bg.Transparency = true, Color3.fromRGB(15, 15, 15), 0.45
        bg.Position, bg.Size, bg.Visible = FIXED_POS, Vector2.new(300, 40), true
        table.insert(overlayObjects, bg)

        local accent = drawLib.new("Square")
        accent.Filled, accent.Color = true, Color3.fromRGB(191, 64, 191)
        accent.Position, accent.Size, accent.Visible = FIXED_POS, Vector2.new(4, 40), true
        table.insert(overlayObjects, accent)

        local labelActive = drawLib.new("Text")
        labelActive.Text, labelActive.Color, labelActive.Size = "ACTIVE SCRIPT", Color3.fromRGB(191, 64, 191), 13
        labelActive.Position, labelActive.Visible, labelActive.Outline = FIXED_POS + Vector2.new(12, 4), true, true
        table.insert(overlayObjects, labelActive)

        local labelName = drawLib.new("Text")
        labelName.Text, labelName.Color, labelName.Size = wrapName(scriptName, 28), Color3.fromRGB(235, 235, 235), 13
        labelName.Position, labelName.Visible, labelName.Outline = FIXED_POS + Vector2.new(12, 19), true, true
        table.insert(overlayObjects, labelName)
    end)
end

