local HttpService = game:GetService("HttpService")
local HUB_URL = type(_G.list) == "string" and _G.list ~= "" and _G.list or "https://raw.githubusercontent.com/leo0ntop0-alt/rolbox/refs/heads/main/myscript.lua"

local scripts = {}
local ready = false
local currentId = tostring(game.PlaceId)
local detectedMatches = {}

-- ─────────────────────────────────────────
--  NOTIFY & UTILITY
-- ─────────────────────────────────────────
local function notify(title, text)
    local success = pcall(function()
        if UI and UI.Notify then
            UI.Notify({ Title = title, Content = text, Duration = 5 })
        elseif UI and UI.Notification then
            UI.Notification(title, text, 5)
        end
    end)
    print("[Matcha Hub] " .. title .. ": " .. text)
end

local function formatID(val)
    return string.format("%.0f", tonumber(val) or 0)
end

local function runGameDetection()
    table.clear(detectedMatches)
    if not scripts or #scripts == 0 then return end
    local myId = formatID(game.PlaceId)
    for _, s in ipairs(scripts) do
        local rawId = s.placeId or s.gameId
        if rawId then
            if type(rawId) == "table" then
                for _, v in ipairs(rawId) do
                    if formatID(v) == myId then table.insert(detectedMatches, s) break end
                end
            elseif formatID(rawId) == myId then
                table.insert(detectedMatches, s)
            end
        end
    end
end

-- ─────────────────────────────────────────
--  DATA PERSISTENCE
-- ─────────────────────────────────────────
local FAV_FILE = "matcha_favorites.json"
local favorites = {}

local function loadFavorites()
    local ok, raw = pcall(readfile, FAV_FILE)
    if ok and raw and raw ~= "" then
        local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
        if ok2 and type(data) == "table" then favorites = data return end
    end
    favorites = {}
end

local function saveFavorites()
    local ok, encoded = pcall(function() return HttpService:JSONEncode(favorites) end)
    if ok then pcall(writefile, FAV_FILE, encoded) end
end

local function isFavorite(name)
    for _, v in ipairs(favorites) do if v == name then return true end end
    return false
end

local function toggleFavorite(name)
    local found = false
    for i, v in ipairs(favorites) do
        if v == name then table.remove(favorites, i) found = true break end
    end
    if not found then table.insert(favorites, name) end
    saveFavorites()
end

task.spawn(function()
    local ok, raw = pcall(game.HttpGet, game, HUB_URL)
    if ok and raw then
        local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
        if ok2 and type(data) == "table" then scripts = data end
    end
    ready = true
    runGameDetection()
    notify("System", "Ready to serve.")
end)

local function wrap(t, l)
    l = l or 22
    if not t then return "—" end
    return #t <= l and t or t:sub(1, l-3) .. "..."
end

-- ─────────────────────────────────────────
--  MAIN UI (ALIGNMENT OPTIMIZED)
-- ─────────────────────────────────────────
UI.AddTab("Script Hub", function(tab)
    if not ready or not scripts then 
        tab:Section("Status", "Left"):Text("Aligning Components...") 
        return 
    end
    
    loadFavorites()
    local nav = tab:Section("", "Left", {"Explorer", "Favorites"})

    if nav.page == 0 then
        -- LEFT COLUMN
        local searchSec = tab:Section("Search Engine", "Left")
        searchSec:InputText("q", "Filter by name...", "")
        local q = (UI.GetValue("q") or ""):lower()

        local filtered = {}
        for _, s in ipairs(scripts) do
            if q == "" or (s.name and s.name:lower():find(q, 1, true)) then table.insert(filtered, s) end
        end

        local browseSec = tab:Section("Script Browser (".. #filtered ..")", "Left")
        local names = {}
        for _, s in ipairs(filtered) do 
            table.insert(names, (isFavorite(s.name) and "★ " or "") .. wrap(s.name)) 
        end
        
        browseSec:Combo("list_" .. q, "Select Script", names, 0)
        local chosenIdx = UI.GetValue("list_" .. q)
        local chosen = (chosenIdx and filtered[chosenIdx + 1]) or nil

        -- RIGHT COLUMN (DETECTION)
        local autoSec = tab:Section("Game Detection (" .. currentId .. ")", "Right")
        if #detectedMatches > 0 then
            local dNames = {}
            for _, s in ipairs(detectedMatches) do table.insert(dNames, wrap(s.name)) end
            local detKey = "det_" .. currentId .. "_" .. #detectedMatches
            autoSec:Combo(detKey, "Matched Results", dNames, 0)
            
            local dIdx = UI.GetValue(detKey)
            local dChosen = (dIdx and detectedMatches[dIdx + 1]) or nil
            
            if dChosen then
                autoSec:Button("Execute Matched Script", 210, 36, function()
                    local fn = loadstring(dChosen.script)
                    if fn then notify("Match Found", dChosen.name) task.spawn(fn) end
                end)
            end
        else
            autoSec:Text("No scripts found for this ID.")
        end

        -- RIGHT COLUMN (EXECUTION ALIGNMENT FIX)
        if chosen then
            local controlSec = tab:Section("Execution Panel", "Right")
            
            -- Explicitly calling text first to anchor the left alignment
            controlSec:Text("Script: " .. wrap(chosen.name, 26))
            controlSec:Text("Author: " .. (chosen.uploader or chosen.author or "Unknown"))
            
            -- Space separator for visual clarity
            controlSec:Text(" ") 
            
            controlSec:Button(isFavorite(chosen.name) and "[-] REMOVE FAVORITE" or "[+] SAVE FAVORITE", 160, 32, function() 
                toggleFavorite(chosen.name) 
                notify("Update", "Vault modified.")
            end)
            
            controlSec:Button(">> RUN SEQUENCE", 210, 42, function()
                local fn = loadstring(chosen.script)
                if fn then notify("Executing", chosen.name) task.spawn(fn) end
            end)
        end

    elseif nav.page == 1 then
        -- FAVORITES
        local favs = {}
        for _, s in ipairs(scripts) do if isFavorite(s.name) then table.insert(favs, s) end end
        
        local favSec = tab:Section("Saved Vault", "Left")
        if #favs > 0 then
            local fNames = {}
            for _, s in ipairs(favs) do table.insert(fNames, "★ " .. wrap(s.name)) end
            favSec:Combo("fav_list", "Select Saved", fNames, 0)
            local fIdx = UI.GetValue("fav_list")
            local fChosen = (fIdx and favs[fIdx + 1]) or nil
            
            if fChosen then
                favSec:Button("Delete Entry", 120, 30, function() toggleFavorite(fChosen.name) end)
                
                local fExec = tab:Section("Vault Command", "Right")
                fExec:Text("Target: " .. wrap(fChosen.name, 25))
                fExec:Button("Execute Entry", 210, 40, function() 
                    local fn = loadstring(fChosen.script)
                    if fn then notify("Vault", fChosen.name) task.spawn(fn) end
                end)
            end
        else
            favSec:Text("Vault is currently empty.")
        end
    end
end)

