local HttpService = game:GetService("HttpService")
local HUB_URL = type(_G.list) == "string" and _G.list ~= "" and _G.list or "https://raw.githubusercontent.com/leo0ntop0-alt/rolbox/refs/heads/main/myscript.lua"

local scripts = {}
local favorites = {}
local ready = false
local currentId = tostring(game.PlaceId)
local detectedMatches = {}
local forcedReset = 0

-- ─────────────────────────────────────────
--  CORE PERSISTENCE
-- ─────────────────────────────────────────
local function saveToDisk()
    local success, content = pcall(function() return HttpService:JSONEncode(favorites) end)
    if success then writefile("Matcha_Favs_V3.json", content) end
end

local function loadFromDisk()
    if isfile("Matcha_Favs_V3.json") then
        local success, content = pcall(function() return HttpService:JSONDecode(readfile("Matcha_Favs_V3.json")) end)
        if success and type(content) == "table" then favorites = content end
    else
        favorites = {}
    end
end

local function isFavorited(scriptName)
    for _, f in ipairs(favorites) do
        if tostring(f.name) == tostring(scriptName) then return true end
    end
    return false
end

-- ─────────────────────────────────────────
--  SYNC ENGINE
-- ─────────────────────────────────────────
local function runGameDetection()
    -- BUG FIX 1: table.clear doesn't exist in Luau VM, replace with reassignment
    detectedMatches = {}
    local myId = tostring(game.PlaceId)
    currentId = myId
    for _, s in ipairs(scripts) do
        -- BUG FIX 2: placeId arrives as string from the JSON gsub protection,
        -- so compare tostring(v) == myId which already handles both cases
        local pid = s.placeId or s.gameId
        if pid ~= nil and tostring(pid) ~= "0" then
            if type(pid) == "table" then
                for _, v in ipairs(pid) do
                    if tostring(v) == myId then
                        table.insert(detectedMatches, s)
                        break
                    end
                end
            elseif tostring(pid) == myId then
                table.insert(detectedMatches, s)
            end
        end
    end
end

local function syncDatabase()
    ready = false
    loadFromDisk()
    local ok, rawText = pcall(game.HttpGet, game, HUB_URL)
    if ok and rawText then
        -- Protect large integers from Luau JSON precision loss
        local protectedJson = rawText:gsub('("placeId"%s*:%s*)(%d+)', '%1"%2"')
        protectedJson = protectedJson:gsub('("gameId"%s*:%s*)(%d+)', '%1"%2"')
        local ok2, data = pcall(function() return HttpService:JSONDecode(protectedJson) end)
        if ok2 and type(data) == "table" then
            scripts = data
            ready = true
            runGameDetection()
            return true
        end
    end
    ready = true -- BUG FIX 3: if fetch fails, set ready=true so UI shows error state instead of spinning forever
    return false
end

task.spawn(syncDatabase)

local function comboWrap(name, starred)
    -- Build label with star prefix AFTER truncating the name, so the emoji never gets cut
    local limit = 28
    local str = tostring(name or "Unknown")
    local truncated = (#str <= limit and str or str:sub(1, limit - 3) .. "...")
    return starred and ("⭐ " .. truncated) or truncated
end

-- ─────────────────────────────────────────
--  INTERFACE BUILD
-- ─────────────────────────────────────────
UI.AddTab("Script Library V2", function(tab)
    if not ready then
        tab:Section("Status", "Left"):Text("Syncing Cloud...")
        return
    end

    local nav = tab:Section("", "Left", {"Explorer", "Favorites"})

    -- ══════════════════════════════════════
    --  EXPLORER PAGE
    -- ══════════════════════════════════════
    if nav.page == 0 then

        -- Search Engine
        local searchSec = tab:Section("Search Engine", "Left")
        searchSec:InputText("q", "Filter Scripts...", "")
        local q = (UI.GetValue("q") or ""):lower()

        local filtered = {}
        for _, s in ipairs(scripts) do
            if q == "" or (s.name and s.name:lower():find(q, 1, true)) then
                table.insert(filtered, s)
            end
        end

        local browseSec = tab:Section("Scripts (" .. #filtered .. ")", "Left")
        local names = {}
        for _, s in ipairs(filtered) do
            table.insert(names, comboWrap(s.name, isFavorited(s.name)))
        end

        -- BUG FIX 4: if filtered is empty, show a placeholder so the combo doesn't crash
        if #names == 0 then names = {"No results"} end

        local comboKey = "list_" .. q .. "_v" .. forcedReset .. "_f" .. #favorites
        browseSec:Combo(comboKey, "Select Script", names, 0)
        local chosenIdx = UI.GetValue(comboKey)
        local chosen = (chosenIdx and #filtered > 0 and filtered[chosenIdx + 1]) or nil

        -- Game Detection
        local autoSec = tab:Section("Game Detection", "Right")
        autoSec:Text("Current ID: " .. currentId)

        if #detectedMatches > 0 then
            local dNames = {}
            for _, s in ipairs(detectedMatches) do
                table.insert(dNames, comboWrap(s.name, isFavorited(s.name)))
            end

            local detKey = "det_res_" .. currentId .. "_v" .. forcedReset
            autoSec:Combo(detKey, "Matches", dNames, 0)
            local dIdx = UI.GetValue(detKey)
            local dChosen = (dIdx and detectedMatches[dIdx + 1]) or nil

            if dChosen then
                autoSec:Button("Execute Match", 200, 36, function()
                    local fn, err = loadstring(dChosen.script)
                    -- BUG FIX 6: loadstring can return nil + error, guard before calling
                    if fn then
                        task.spawn(fn)
                    else
                        warn("[ScriptLib] Load error: " .. tostring(err))
                    end
                end)
            end
        else
            autoSec:Text("No matches for this game.")
            autoSec:Button("Refresh", 140, 30, function()
                -- BUG FIX 7: syncDatabase is a regular function, wrap in task.spawn
                -- so the UI callback doesn't block
                task.spawn(syncDatabase)
            end)
        end

        -- Execution Panel
        if chosen then
            local controlSec = tab:Section("Execution Panel", "Right")
            controlSec:Text("Selected: " .. (chosen.name or "Unknown"))
            controlSec:Text("Author: " .. (chosen.uploader or chosen.author or "Unknown"))

            -- BUG FIX 8: fIdx search used wrong comparison (was comparing favorites index
            -- but then using it to table.remove later with +1 offset — unify the logic)
            local fIdx = nil
            for i, f in ipairs(favorites) do
                if f.name == chosen.name then fIdx = i break end
            end

            local favLabel = fIdx and "Remove Favorite" or "Star Favorite"

            controlSec:Button(favLabel, 150, 34, function()
                if fIdx then
                    table.remove(favorites, fIdx)
                else
                    table.insert(favorites, {
                        name = chosen.name,
                        author = chosen.uploader or chosen.author or "Unknown",
                        script = chosen.script
                    })
                end
                saveToDisk()
                forcedReset = forcedReset + 1
            end)

            controlSec:Button("Run Selected Script            ", 200, 40, function()
                local fn, err = loadstring(chosen.script)
                if fn then
                    task.spawn(fn)
                else
                    warn("[ScriptLib] Load error: " .. tostring(err))
                end
            end)
        end

    -- ══════════════════════════════════════
    --  FAVORITES PAGE
    -- ══════════════════════════════════════
    elseif nav.page == 1 then
        local fCount = #favorites
        local favSec = tab:Section("Your Favorites (" .. fCount .. ")", "Left")

        if fCount == 0 then
            favSec:Text("List is empty.")
        else
            local fNames = {}
            for _, f in ipairs(favorites) do
                table.insert(fNames, comboWrap(f.name, true))
            end

            local favComboKey = "fav_list_v" .. forcedReset
            favSec:Combo(favComboKey, "Select Favorite", fNames, 0)
            local fIdx = UI.GetValue(favComboKey)
            local fChosen = (fIdx and favorites[fIdx + 1]) or nil

            if fChosen then
                local fControl = tab:Section("Favorite Actions", "Right")
                fControl:Text("Selected: " .. tostring(fChosen.name or "Unknown"))
                fControl:Text("Author: " .. tostring(fChosen.author or "Unknown"))

                fControl:Button("Remove Favorite", 150, 34, function()
                    -- BUG FIX 9: was using fIdx+1 but fIdx is already 0-based from UI,
                    -- so fIdx+1 is the correct Lua index — this was correct but only works
                    -- if fIdx is never nil; guard it
                    if fIdx then
                        table.remove(favorites, fIdx + 1)
                        saveToDisk()
                        forcedReset = forcedReset + 1
                    end
                end)

                fControl:Button("Run Favorite Script         ", 190, 40, function()
                    local fn, err = loadstring(fChosen.script)
                    if fn then
                        task.spawn(fn)
                    else
                        warn("[ScriptLib] Load error: " .. tostring(err))
                    end
                end)
            end
        end
    end
end)

notify("Script Library V2 tab was added to your Matcha interface", "Script Library V2", 7)
warn("[ScriptLib] RECOMMENDED: Put the Script Library in Matcha auto execute so it stays in your Matcha interface")
