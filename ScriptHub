local comboId, favComboId = 0, 0
local prevQ, prevCat = "", -1

UI.AddTab("Script Library V2", function(tab)
    if not ready then tab:Section("Navigation"):Text("Connecting...") return end

    local navSec = tab:Section("", "Left", {"Library", "Favorites"})
    
    local overlaySec = tab:Section("Overlay", "Left")
    overlaySec:Toggle("lib_overlay", "Show Status Overlay", false, function(val)
        overlayEnabled = val
        if not val then destroyOverlay() else buildOverlay("No script active") end
    end)
    overlayEnabled = UI.GetValue("lib_overlay") or false

    if navSec.page == 0 then
        local q = UI.GetValue("lib_q") or ""
        local catIdx = UI.GetValue("lib_cat") or 0
        local catList = (function()
            local s, o = {}, {"All Categories"}
            for _, v in ipairs(scripts) do if v.game and not s[v.game] then s[v.game]=true table.insert(o, wrapName(v.game)) end end
            table.sort(o, function(a,b) return a=="All Categories" or (b~="All Categories" and a<b) end)
            return o
        end)()
        
        if q ~= prevQ or catIdx ~= prevCat then prevQ, prevCat = q, catIdx comboId = comboId + 1 end

        local searchSec = tab:Section("Navigation", "Left")
        searchSec:InputText("lib_q", "Search name/game", "")
        searchSec:Combo("lib_cat", "Category", catList, catIdx)

        local filtered = {}
        for _, s in ipairs(scripts) do
            local catFilter = catList[catIdx + 1]
            local skip = (catFilter ~= "All Categories" and wrapName(s.game) ~= catFilter)
            if not skip and q ~= "" then
                local inN = (s.name or ""):lower():find(q:lower(), 1, true)
                local inG = (s.game or ""):lower():find(q:lower(), 1, true)
                if not inN and not inG then skip = true end
            end
            if not skip then table.insert(filtered, s) end
        end

        local names = {}
        for _, s in ipairs(filtered) do table.insert(names, (isFavorite(s.name) and "★ " or "") .. wrapName(s.name)) end

        local listSec = tab:Section(#filtered .. " Scripts Found", "Left")
        listSec:Combo("lib_pick_" .. comboId, "Select Script", #names > 0 and names or {"No Results"}, 0)
        
        local chosen = filtered[(UI.GetValue("lib_pick_" .. comboId) or 0) + 1]
        if chosen then
            listSec:Button(isFavorite(chosen.name) and "★ Remove Favorite" or "☆ Add Favorite", function() 
                local found = false
                for i, v in ipairs(favorites) do if v == chosen.name then table.remove(favorites, i) found = true break end end
                if not found then table.insert(favorites, chosen.name) end
                saveFavorites()
                comboId, favComboId = comboId + 1, favComboId + 1
                notify("Matcha", found and "Removed Favorite" or "Added Favorite")
            end)

            local infoSec = tab:Section("Script Details", "Right", {"Info", "Preview"})
            if infoSec.page == 0 then
                infoSec:Text("Name: " .. wrapName(chosen.name))
                infoSec:Text("Uploader: " .. (chosen.uploader or "Unknown"))
                infoSec:Text("Category: " .. (chosen.game or "Unknown"))
            else
                infoSec:Text(chosen.script:len() > 110 and chosen.script:sub(1, 110) .. "..." or chosen.script)
            end

            local gEntries = parseGlobals(chosen.script)
            local cfgPrefix = (chosen.name or ""):gsub("[^%w]", "_")
            if gEntries then
                local cfgSec = tab:Section("_G Config", "Left")
                for _, entry in ipairs(gEntries) do
                    if entry.kind == "single" then cfgSec:InputText("gv_"..cfgPrefix.."_"..entry.name, "_G."..entry.name, entry.default)
                    elseif entry.kind == "block" then
                        cfgSec:Text("_G."..entry.name)
                        for _, f in ipairs(entry.fields) do cfgSec:InputText("gv_"..cfgPrefix.."_"..entry.name.."_"..f.key, f.key, f.default) end
                    end
                end
            end

            tab:Section("Action", "Right"):Button("Execute Script", 210, 34, function()
                local final = chosen.script
                if gEntries then final = buildGlobalsOverride(gEntries, cfgPrefix) .. "\n" .. final end
                local fn = loadstring(final)
                if fn then 
                    task.spawn(fn) 
                    playExecuteSound() 
                    buildOverlay(chosen.name)
                    notify("Matcha", "Executed: " .. chosen.name)
                end
            end)
        end

    elseif navSec.page == 1 then
        local favScripts = {}
        for _, s in ipairs(scripts) do if isFavorite(s.name) then table.insert(favScripts, s) end end
        
        local favSec = tab:Section(#favScripts .. " Favorites", "Left")
        if #favScripts > 0 then
            local fnms = {}
            for _, s in ipairs(favScripts) do table.insert(fnms, "★ " .. wrapName(s.name)) end
            favSec:Combo("fav_p_" .. favComboId, "Select Favorite", fnms, 0)
            
            local fchosen = favScripts[(UI.GetValue("fav_p_" .. favComboId) or 0) + 1]
            if fchosen then
                favSec:Button("Remove Favorite", function() 
                    for i, v in ipairs(favorites) do if v == fchosen.name then table.remove(favorites, i) break end end
                    saveFavorites()
                    favComboId, comboId = favComboId + 1, comboId + 1
                    notify("Matcha", "Removed Favorite")
                end)

                local fInfoSec = tab:Section("Favorite Details", "Right", {"Info", "Preview"})
                if fInfoSec.page == 0 then
                    fInfoSec:Text("Name: " .. wrapName(fchosen.name))
                    fInfoSec:Text("Uploader: " .. (fchosen.uploader or "Unknown"))
                    fInfoSec:Text("Category: " .. (fchosen.game or "Unknown"))
                else
                    fInfoSec:Text(fchosen.script:len() > 110 and fchosen.script:sub(1, 110) .. "..." or fchosen.script)
                end

                local gEntriesF = parseGlobals(fchosen.script)
                local cfgPrefixF = (fchosen.name or ""):gsub("[^%w]", "_")
                if gEntriesF then
                    local cfgSecF = tab:Section("_G Config", "Left")
                    for _, entry in ipairs(gEntriesF) do
                        if entry.kind == "single" then cfgSecF:InputText("gv_"..cfgPrefixF.."_"..entry.name, "_G."..entry.name, entry.default)
                        elseif entry.kind == "block" then
                            cfgSecF:Text("_G."..entry.name)
                            for _, f in ipairs(entry.fields) do cfgSecF:InputText("gv_"..cfgPrefixF.."_"..entry.name.."_"..f.key, f.key, f.default) end
