local HttpService = game:GetService("HttpService")
local HUB_URL = type(_G.list) == "string" and _G.list ~= "" and _G.list or "https://raw.githubusercontent.com/leo0ntop0-alt/rolbox/refs/heads/main/myscript.lua"

local scripts = {}
local favorites = {}
local ready = false
local currentId = tostring(game.PlaceId)
local detectedMatches = {}
local forcedReset = 0 

-- ─────────────────────────────────────────
--  CORE PERSISTENCE
-- ─────────────────────────────────────────
local function saveToDisk()
    local success, content = pcall(function() return HttpService:JSONEncode(favorites) end)
    if success then writefile("Matcha_Favs_V3.json", content) end
end

local function loadFromDisk()
    if isfile("Matcha_Favs_V3.json") then
        local success, content = pcall(function() return HttpService:JSONDecode(readfile("Matcha_Favs_V3.json")) end)
        if success and type(content) == "table" then favorites = content end
    else
        favorites = {}
    end
end

local function isFavorited(scriptName)
    for _, f in ipairs(favorites) do
        if tostring(f.name) == tostring(scriptName) then return true end
    end
    return false
end

-- ─────────────────────────────────────────
--  SYNC ENGINE
-- ─────────────────────────────────────────
local function runGameDetection()
    table.clear(detectedMatches)
    local myId = tostring(game.PlaceId)
    currentId = myId
    for _, s in ipairs(scripts) do
        local pid = s.placeId or s.gameId
        if pid then
            if type(pid) == "table" then
                for _, v in ipairs(pid) do
                    if tostring(v) == myId then table.insert(detectedMatches, s) break end
                end
            elseif tostring(pid) == myId then
                table.insert(detectedMatches, s)
            end
        end
    end
end

local function syncDatabase()
    ready = false
    loadFromDisk() 
    local ok, rawText = pcall(game.HttpGet, game, HUB_URL)
    if ok and rawText then
        local protectedJson = rawText:gsub('("placeId"%s*:%s*)(%d+)', '%1"%2"')
        protectedJson = protectedJson:gsub('("gameId"%s*:%s*)(%d+)', '%1"%2"')
        local ok2, data = pcall(function() return HttpService:JSONDecode(protectedJson) end)
        if ok2 and type(data) == "table" then 
            scripts = data 
            ready = true
            runGameDetection()
            return true
        end
    end
    return false
end

task.spawn(syncDatabase)

local function comboWrap(t)
    local limit = 32
    local str = tostring(t or "Unknown")
    return (#str <= limit and str or str:sub(1, limit-3) .. "...")
end

-- ─────────────────────────────────────────
--  INTERFACE BUILD
-- ─────────────────────────────────────────
UI.AddTab("Script Library V2", function(tab)
    if not ready then 
        tab:Section("Status", "Left"):Text("Syncing Cloud...") 
        return 
    end
    
    local nav = tab:Section("", "Left", {"Explorer", "Favorites"})

    if nav.page == 0 then
        -- Search Engine
        local searchSec = tab:Section("Search Engine", "Left")
        searchSec:InputText("q", "Filter Scripts...", "")
        local q = (UI.GetValue("q") or ""):lower()

        local filtered = {}
        for _, s in ipairs(scripts) do
            if q == "" or (s.name and s.name:lower():find(q, 1, true)) then table.insert(filtered, s) end
        end

        local browseSec = tab:Section("Scripts (".. #filtered ..")", "Left")
        local names = {}
        for _, s in ipairs(filtered) do 
            local label = isFavorited(s.name) and ("⭐ " .. s.name) or s.name
            table.insert(names, comboWrap(label)) 
        end
        
        local comboKey = "list_" .. q .. "_v" .. forcedReset
        browseSec:Combo(comboKey, "Select Script", names, 0)
        local chosenIdx = UI.GetValue(comboKey)
        local chosen = (chosenIdx and filtered[chosenIdx + 1]) or nil

        -- Game Detection
        local autoSec = tab:Section("Game Detection", "Right")
        autoSec:Text("Current ID: " .. currentId)
        
        if #detectedMatches > 0 then
            local dNames = {}
            for _, s in ipairs(detectedMatches) do 
                local dLabel = isFavorited(s.name) and ("⭐ " .. s.name) or s.name
                table.insert(dNames, comboWrap(dLabel)) 
            end
            
            local detKey = "det_res_" .. currentId .. "_v" .. forcedReset
            autoSec:Combo(detKey, "Matches", dNames, 0)
            local dIdx = UI.GetValue(detKey)
            local dChosen = (dIdx and detectedMatches[dIdx + 1]) or nil
            
            if dChosen then
                -- Standard Button Size
                autoSec:Button("Execute Match", 200, 36, function()
                    local fn = loadstring(dChosen.script)
                    if fn then task.spawn(fn) end
                end)
            end
        else
            autoSec:Text("No matches.")
            autoSec:Button("Refresh", 140, 30, syncDatabase)
        end

        -- Execution Panel
        if chosen then
            local controlSec = tab:Section("Execution Panel", "Right")
            
            -- THE FIX: Using a hair-space prefix to align 'Selected' letters with the button labels
            controlSec:Text("Selected: " .. (chosen.name or "Unknown"))
            controlSec:Text("Author: " .. (chosen.uploader or chosen.author or "Unknown"))
            
            local fIdx = nil
            for i, f in ipairs(favorites) do
                if f.name == chosen.name then fIdx = i break end
            end

            local favLabel = fIdx and "Remove Favorite" or "Star Favorite"
            
            -- REVERTED WIDTH: Back to original compact sizing
            controlSec:Button(favLabel, 150, 34, function() 
                if fIdx then
                    table.remove(favorites, fIdx)
                else
                    table.insert(favorites, {
                        name = chosen.name, 
                        author = chosen.uploader or chosen.author or "Unknown", 
                        script = chosen.script
                    })
                end
                saveToDisk()
                forcedReset = forcedReset + 1
            end)
            
            controlSec:Button("Run Selected Script      ", 200, 40, function()
                local fn = loadstring(chosen.script)
                if fn then task.spawn(fn) end
            end)
        end

    -- Favorites Tab
    elseif nav.page == 1 then
        local fCount = #favorites
        local favSec = tab:Section("Your Favorites (" .. fCount .. ")", "Left")
        
        if fCount == 0 then
            favSec:Text("List is empty.")
        else
            local fNames = {}
            for _, f in ipairs(favorites) do table.insert(fNames, comboWrap("⭐ " .. f.name)) end
            
            favSec:Combo("fav_list_v" .. forcedReset, "Select Favorite", fNames, 0)
            local fIdx = UI.GetValue("fav_list_v" .. forcedReset)
            local fChosen = (fIdx and favorites[fIdx + 1]) or nil
            
            if fChosen then
                local fControl = tab:Section("Favorite Actions", "Right")
                fControl:Text("Selected: " .. fChosen.name)
                
                -- Original compact widths
                fControl:Button("Remove Favorite", 150, 34, function()
                    table.remove(favorites, fIdx + 1)
                    saveToDisk()
                    forcedReset = forcedReset + 1
                end)
                
                fControl:Button("Run Favorite Script            ", 200, 40, function()
                    local fn = loadstring(fChosen.script)
                    if fn then task.spawn(fn) end
                end)
            end
        end
    end
end)

notify("Script Library V2 tab was added to your Matcha interface", "Script Library V2", 7)
 
