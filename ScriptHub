end)

local function parseGlobals(src)
    local entries = {}
    local pos = 1
    while pos <= #src do
        local s, e, gname = src:find("_G%.([%w_]+)%s*=", pos)
        if not s then break end
        local _, wsEnd = src:find("^%s*", e + 1)
        local valPos = (wsEnd or e) + 1
        if src:sub(valPos, valPos) == "{" then
            local depth, blockEnd = 0, valPos
            for i = valPos, #src do
                local c = src:sub(i, i)
                if c == "{" then depth = depth + 1 elseif c == "}" then depth = depth - 1 if depth == 0 then blockEnd = i break end end
            end
            local fields = {}
            for line in src:sub(valPos + 1, blockEnd - 1):gmatch("[^\n]+") do
                local k, v = line:match("^%s*([%w_]+)%s*=%s*(.-)%s*,?%s*$")
                if k and v then table.insert(fields, {key = k, default = v}) end
            end
            if #fields > 0 then table.insert(entries, {kind = "block", name = gname, fields = fields}) end
            pos = blockEnd + 1
        else
            local line = src:match("^([^\n]*)", valPos)
            if line then
                local val = line:match("^(.-)%s*;?%s*$") or line
                table.insert(entries, {kind = "single", name = gname, default = val:match("^%s*(.-)%s*$")})
                pos = valPos + #line + 1
            else pos = e + 1 end
        end
    end
    return #entries > 0 and entries or nil
end

local function buildGlobalsOverride(entries, prefix)
    local parts = {}
    for _, entry in ipairs(entries) do
        if entry.kind == "single" then
            local val = tostring(UI.GetValue("gv_" .. prefix .. "_" .. entry.name) or entry.default)
            table.insert(parts, "_G." .. entry.name .. " = " .. val)
        elseif entry.kind == "block" then
            table.insert(parts, "_G." .. entry.name .. " = {")
            for _, f in ipairs(entry.fields) do
                local val = tostring(UI.GetValue("gv_" .. prefix .. "_" .. entry.name .. "_" .. f.key) or f.default)
                table.insert(parts, "    " .. f.key .. " = " .. val .. ",")
            end
            table.insert(parts, "}")
        end
    end
    return table.concat(parts, "\n")
end

