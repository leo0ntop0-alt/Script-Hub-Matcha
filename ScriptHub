local HUB_URL = type(_G.list) == "string" and _G.list ~= "" and _G.list or "https://raw.githubusercontent.com/leo0ntop0-alt/rolbox/refs/heads/main/myscript.lua"
local RECENTS_FILE = "ScriptLibrary_Recents.json"
local EXECUTIONS_FILE = "ScriptLibrary_Executions.json"

local scripts = {}
local recents = {}
local matches = {}
local executions = {}
local ready = false
local uiRefresh = 0
local lastPlaceId = ""

-- Services
local HttpService = game:GetService("HttpService")

-- Get IDs from script entry (handles single ID or array of IDs)
local function getIds(entry)
	local ids = {}
	
	-- Add placeId if exists
	if entry.placeId then
		if type(entry.placeId) == "table" then
			for _, v in ipairs(entry.placeId) do
				table.insert(ids, tostring(v))
			end
		else
			table.insert(ids, tostring(entry.placeId))
		end
	end
	
	-- Add gameId if exists
	if entry.gameId then
		if type(entry.gameId) == "table" then
			for _, v in ipairs(entry.gameId) do
				table.insert(ids, tostring(v))
			end
		else
			table.insert(ids, tostring(entry.gameId))
		end
	end
	
	-- Add universeId if exists
	if entry.universeId then
		if type(entry.universeId) == "table" then
			for _, v in ipairs(entry.universeId) do
				table.insert(ids, tostring(v))
			end
		else
			table.insert(ids, tostring(entry.universeId))
		end
	end
	
	return ids
end

-- Update matches based on current game UniverseId only
local function updateMatches()
	matches = {}
	local universeId = tostring(game.GameId)
	
	for _, sc in pairs(scripts) do
		local ids = getIds(sc)
		for _, id in pairs(ids) do
			local idStr = tostring(id)
			if idStr == universeId then
				table.insert(matches, sc)
				break
			end
		end
	end
end

-- Load scripts from hub
task.spawn(function()
	local ok, raw = pcall(game.HttpGet, game, HUB_URL)
	if not ok or not raw then
		warn("[ScriptLib] Failed to load hub: " .. tostring(raw))
		warn("[ScriptLib] Check if the URL is correct and accessible")
		ready = true
		return
	end
	
	-- Fix numeric IDs in JSON (convert to strings)
	raw = raw:gsub('("placeId"%s*:%s*)(%d+)', '%1"%2"')
	raw = raw:gsub('("gameId"%s*:%s*)(%d+)', '%1"%2"')
	raw = raw:gsub('("universeId"%s*:%s*)(%d+)', '%1"%2"')
	
	-- Fix missing commas between fields (common JSON error)
	-- Number followed by newline followed by string
	raw = raw:gsub('(%d)%s*\n%s*"', '%1,\n  "')
	-- Number followed by newline followed by number
	raw = raw:gsub('(%d)%s*\n%s*(%d)', '%1,\n  %2')
	-- String followed by newline followed by string
	raw = raw:gsub('"%s*\n%s*"', '",\n  "')
	-- String followed by newline followed by number
	raw = raw:gsub('"%s*\n%s*(%d)', '",\n  %1')
	
	local ok2, data = pcall(HttpService.JSONDecode, HttpService, raw)
	if ok2 and type(data) == "table" then
		scripts = data
		updateMatches()
	else
		warn("[ScriptLib] Failed to parse JSON: " .. tostring(data))
		warn("[ScriptLib] First 100 chars of response: " .. raw:sub(1, 100))
	end
	ready = true
end)

-- Recents Data Persistence
local function saveRecents()
	pcall(function()
		local cleanData = {}
		for _, recent in ipairs(recents) do
			table.insert(cleanData, {
				name = recent.name,
				script = recent.script,
				uploader = recent.uploader,
				game = recent.game
			})
		end
		writefile(RECENTS_FILE, HttpService:JSONEncode(cleanData))
	end)
end

local function loadRecents()
	if not isfile(RECENTS_FILE) then
		recents = {}
		return
	end
	
	pcall(function()
		local data = HttpService:JSONDecode(readfile(RECENTS_FILE))
		if type(data) == "table" then
			recents = data
		end
	end)
end

local function addToRecents(scriptData)
	-- Remove existing entry
	for i, recent in ipairs(recents) do
		if recent.name == scriptData.name then
			table.remove(recents, i)
			break
		end
	end
	
	-- Add to top
	table.insert(recents, 1, {
		name = scriptData.name,
		script = scriptData.script,
		uploader = scriptData.uploader,
		game = scriptData.game
	})
	
	-- Keep only last 20 items
	if #recents > 20 then
		for i = 21, #recents do
			recents[i] = nil
		end
	end
	
	task.defer(saveRecents)
	uiRefresh = uiRefresh + 1
end

-- Load recents on startup (deferred to prevent deadlock)
task.defer(loadRecents)

-- Execution Tracking (counts only, not users)
local function loadExecutions()
	if not isfile(EXECUTIONS_FILE) then
		executions = {}
		return
	end
	
	pcall(function()
		local data = HttpService:JSONDecode(readfile(EXECUTIONS_FILE))
		if type(data) == "table" then
			executions = data
		end
	end)
end

local function saveExecutions()
	pcall(function()
		writefile(EXECUTIONS_FILE, HttpService:JSONEncode(executions))
	end)
end

local function logExecution(scriptName)
	if not scriptName then return end
	local key = tostring(scriptName)
	executions[key] = (executions[key] or 0) + 1
	task.defer(saveExecutions)
end

local function getExecutionCount(scriptName)
	if not scriptName then return 0 end
	return executions[tostring(scriptName)] or 0
end

-- Load executions on startup (deferred to prevent deadlock)
task.defer(loadExecutions)

-- Helper functions
local function wrapName(text, maxLen)
	maxLen = maxLen or 28
	if #text <= maxLen then return text end
	local result = ""
	while #text > maxLen do
		local chunk = text:sub(1, maxLen)
		local lastSpace = chunk:match(".*()%s") 
		if lastSpace and lastSpace > maxLen * 0.5 then
			result = result .. text:sub(1, lastSpace - 1) .. "\n"
			text = text:sub(lastSpace + 1)
		else
			result = result .. chunk .. "\n"
			text = text:sub(maxLen + 1)
		end
	end
	return result .. text
end

local function buildGameListFrom(list)
	local seen, out = {}, {"All Games"}
	for _, s in ipairs(list) do
		if s.game and not seen[s.game] then
			seen[s.game] = true
			table.insert(out, wrapName(s.game))
		end
	end
	table.sort(out, function(a, b)
		if a == "All Games" then return true end
		if b == "All Games" then return false end
		return a < b
	end)
	return out
end

local function doFilter(search, gameIdx, gameList, sortIdx)
	local q = (search or ""):lower():match("^%s*(.-)%s*$")
	local gameFilter = gameList[gameIdx + 1]
	local out = {}
	for _, s in ipairs(scripts) do
		local skip = false
		if gameFilter ~= "All Games" and wrapName(s.game or "") ~= gameFilter then skip = true end
		if not skip and q ~= "" then
			local inName     = s.name     and s.name:lower():find(q, 1, true)
			local inGame     = s.game     and s.game:lower():find(q, 1, true)
			local inUploader = s.uploader and s.uploader:lower():find(q, 1, true)
			if not inName and not inGame and not inUploader then skip = true end
		end
		if not skip then table.insert(out, s) end
	end
	if sortIdx == 1 then
		table.sort(out, function(a, b) return (a.name or "") < (b.name or "") end)
	elseif sortIdx == 2 then
		table.sort(out, function(a, b) return (a.name or "") > (b.name or "") end)
	elseif sortIdx == 3 then
		table.sort(out, function(a, b) return (a.game or "") < (b.game or "") end)
	elseif sortIdx == 4 then
		-- Filter to only show scripts that have been executed, sorted by usage
		local filtered = {}
		for _, s in ipairs(out) do
			if getExecutionCount(s.name) > 0 then
				table.insert(filtered, s)
			end
		end
		table.sort(filtered, function(a, b)
			local countA = getExecutionCount(a.name)
			local countB = getExecutionCount(b.name)
			if countA ~= countB then
				return countA > countB
			end
			return (a.name or "") < (b.name or "")
		end)
		return filtered
	end
	return out
end


-- Parse _G globals from script source
local function parseGlobals(src)
	local entries = {}
	local pos = 1
	while pos <= #src do
		local s, e, gname = src:find("_G%.([%w_]+)%s*=", pos)
		if not s then break end
		local _, wsEnd = src:find("^%s*", e + 1)
		local valPos = (wsEnd or e) + 1
		if src:sub(valPos, valPos) == "{" then
			local depth, blockEnd = 0, valPos
			for i = valPos, #src do
				local c = src:sub(i, i)
				if c == "{" then
					depth = depth + 1
				elseif c == "}" then
					depth = depth - 1
					if depth == 0 then blockEnd = i break end
				end
			end
			local body = src:sub(valPos + 1, blockEnd - 1)
			local fields = {}
			for line in body:gmatch("[^\n]+") do
				local noComment = line:match("^(.-)%s*%-%-.*$") or line
				local k, v = noComment:match("^%s*([%w_]+)%s*=%s*(.-)%s*,?%s*$")
				if k and v and v ~= "" then
					table.insert(fields, {key = k, default = v})
				end
			end
			if #fields > 0 then
				table.insert(entries, {kind = "block", name = gname, fields = fields})
			end
			pos = blockEnd + 1
		else
			local line = src:match("^([^\n]*)", valPos)
			if line then
				local val = line:match("^(.-)%s*%-%-.*$") or line
				val = val:match("^(.-)%s*;?%s*$") or val
				val = val:match("^%s*(.-)%s*$") or val
				if val ~= "" then
					table.insert(entries, {kind = "single", name = gname, default = val})
				end
				pos = valPos + #line + 1
			else
				pos = e + 1
			end
		end
	end
	return #entries > 0 and entries or nil
end

local function buildGlobalsOverride(entries, prefix)
	local parts = {}
	for _, entry in ipairs(entries) do
		if entry.kind == "single" then
			local wid = "gv_" .. prefix .. "_" .. entry.name
			local val = tostring(UI.GetValue(wid) or entry.default):match("^%s*(.-)%s*$")
			table.insert(parts, "_G." .. entry.name .. " = " .. val)
		elseif entry.kind == "block" then
			table.insert(parts, "_G." .. entry.name .. " = {")
			for _, f in ipairs(entry.fields) do
				local wid = "gv_" .. prefix .. "_" .. entry.name .. "_" .. f.key
				local val = tostring(UI.GetValue(wid) or f.default):match("^%s*(.-)%s*$")
				table.insert(parts, "    " .. f.key .. " = " .. val .. ",")
			end
			table.insert(parts, "}")
		end
	end
	return table.concat(parts, "\n")
end

-- Execute script with recents tracking
local function executeWithTracking(scriptData, gEntries, cfgPrefix)
	if not scriptData or not scriptData.script then return end
	
	local finalScript = scriptData.script
	if gEntries then
		local override = buildGlobalsOverride(gEntries, cfgPrefix)
		finalScript = override .. "\n" .. finalScript
	end
	
	local fn, loadErr = loadstring(finalScript)
	if not fn then
		warn("[ScriptLib] Could not load: " .. tostring(loadErr))
		return
	end
	
	local ok, runErr = pcall(fn)
	if not ok then
		warn("[ScriptLib] Script errored: " .. tostring(runErr))
	end
	
	-- Add to recents after successful execution
	addToRecents(scriptData)
	
	-- Log execution count
	logExecution(scriptData.name)
end

local prevQ, prevGame, prevSort = "", -1, -1
local comboId = 0

-- Main UI
UI.AddTab("Script Library", function(tab)
	if not ready then
		local s = tab:Section("Please wait", "Left")
		s:Text("Loading scripts from the hub...")
		return
	end

	local q       = UI.GetValue("lib_q")    or ""
	local gameIdx = UI.GetValue("lib_game") or 0
	local sortIdx = UI.GetValue("lib_sort") or 0

	local tempList = doFilter(q, 0, {"All Games"}, 0)
	local gameList = buildGameListFrom(#q > 0 and tempList or scripts)

	if gameIdx >= #gameList then
		gameIdx = 0
		UI.SetValue("lib_game", 0)
	end

	-- Navigation with Recents tab
	local mainNav = tab:Section("Library", "Left", {"Explorer", "Recents"})

	if mainNav.page == 0 then
		-- EXPLORER PAGE
		-- Show loaded scripts count
		local statusSec = tab:Section("Status", "Left")
		if #scripts == 0 then
			statusSec:Text("⚠ No scripts loaded from hub")
			statusSec:Text("Check console for errors (F9)")
		else
			statusSec:Text("✓ Loaded " .. #scripts .. " scripts from hub")
		end
		
		local filterSec = tab:Section("Filters", "Left", {"Search", "Game & Sort"})

		if filterSec.page == 0 then
			filterSec:InputText("lib_q", "Name, game, or creator...", "")
			filterSec:Spacing()
			filterSec:Text("Matches name, game and uploader fields.")
		elseif filterSec.page == 1 then
			filterSec:Combo("lib_game", "Game", gameList, gameIdx)
			filterSec:Spacing()
			filterSec:Combo("lib_sort", "Order", {"Default", "Name A-Z", "Name Z-A", "Game A-Z", "Most Used"}, sortIdx)
			filterSec:Spacing()
			filterSec:Button("Clear Filters", function()
				UI.SetValue("lib_q", "")
				UI.SetValue("lib_game", 0)
				UI.SetValue("lib_sort", 0)
			end)
		end

		local changed = (q ~= prevQ or gameIdx ~= prevGame or sortIdx ~= prevSort)
		if changed then
			prevQ, prevGame, prevSort = q, gameIdx, sortIdx
			UI.SetValue("lib_pick", 0)
			comboId = comboId + 1
		end

		local filtered = doFilter(q, gameIdx, gameList, sortIdx)
		local label = #filtered == 1 and "1 script found" or (#filtered .. " scripts found")

		local names = {}
		for _, s in ipairs(filtered) do
			table.insert(names, wrapName(s.name or ""))
		end
		if #names == 0 then names = {"No results"} end

		local listSec = tab:Section(label, "Left")
		local listKey = "lib_pick_" .. q .. "_" .. gameIdx .. "_" .. sortIdx .. "_" .. #filtered
		local currentIdx = UI.GetValue(listKey) or 0
		if currentIdx >= #names then currentIdx = 0 end
		listSec:Combo(listKey, "Script", names, currentIdx)

		local idx    = (UI.GetValue(listKey) or 0) + 1
		local chosen = filtered[idx]

		local cfgPrefix = chosen and (chosen.name or ""):gsub("[^%w]", "_") or ""
		local gEntries  = chosen and chosen.script and parseGlobals(chosen.script) or nil

		if gEntries then
			local cfgSec = tab:Section("_G Config", "Left")
			for _, entry in ipairs(gEntries) do
				if entry.kind == "single" then
					local wid = "gv_" .. cfgPrefix .. "_" .. entry.name
					cfgSec:InputText(wid, "_G." .. entry.name, entry.default)
				elseif entry.kind == "block" then
					cfgSec:Text("_G." .. entry.name)
					cfgSec:Spacing()
					for _, f in ipairs(entry.fields) do
						local wid = "gv_" .. cfgPrefix .. "_" .. entry.name .. "_" .. f.key
						cfgSec:InputText(wid, f.key, f.default)
					end
					cfgSec:Spacing()
				end
			end
		end

		local infoSec = tab:Section("Script Details", "Right", {"Info", "Loadstring"})

		if infoSec.page == 0 then
			if chosen then
				infoSec:Text("Name")
				infoSec:Text(wrapName(chosen.name or "—"))
				infoSec:Spacing()
				infoSec:Text("Creator")
				infoSec:Text(chosen.uploader or "Unknown")
				infoSec:Spacing()
				infoSec:Text("Game")
				infoSec:Text(wrapName(chosen.game or "Unknown"))
				infoSec:Spacing()
				infoSec:Text("Times Executed")
				infoSec:Text(tostring(getExecutionCount(chosen.name)))
			else
				infoSec:Spacing()
				infoSec:Text("No script selected.")
				infoSec:Text("Pick one from the left panel.")
			end
		elseif infoSec.page == 1 then
			if chosen and chosen.script then
				local preview = chosen.script:len() > 110
					and chosen.script:sub(1, 110) .. "..."
					or chosen.script
				infoSec:Text("Loadstring preview:")
				infoSec:Spacing()
				infoSec:Text(preview)
			else
				infoSec:Text("Select a script to see the loadstring.")
			end
		end

		-- Auto Detect Section
		local autoSec = tab:Section("Auto Detect", "Right")
		autoSec:Text("Universe ID: " .. tostring(game.GameId))
		
		-- Auto-refresh if UniverseId changed
		local currentUniverseId = tostring(game.GameId)
		if lastPlaceId ~= currentUniverseId then
			lastPlaceId = currentUniverseId
			updateMatches()
		end
		
		if #matches > 0 then
			local matchNames = {}
			for _, m in ipairs(matches) do
				table.insert(matchNames, wrapName(m.name or ""))
			end
			
			local mKey = "match_" .. currentUniverseId .. "_" .. #matches
			autoSec:Combo(mKey, "Matches", matchNames, 0)
			
			local mIdx = (UI.GetValue(mKey) or 0) + 1
			local chosenMatch = matches[mIdx]
			
			if chosenMatch then
				autoSec:Spacing()
				autoSec:Text("Creator: " .. (chosenMatch.uploader or "Unknown"))
				autoSec:Button("Execute Match", 200, 32, function()
					local autoGEntries = chosenMatch.script and parseGlobals(chosenMatch.script) or nil
					local autoCfgPrefix = (chosenMatch.name or ""):gsub("[^%w]", "_")
					executeWithTracking(chosenMatch, autoGEntries, autoCfgPrefix)
				end)
			end
		else
			autoSec:Spacing()
			autoSec:Text("No scripts for this game")
		end

		local execSec = tab:Section("Execute", "Right")

		if chosen then
			execSec:Text("Selected:  " .. wrapName(chosen.name or "?"))
			if gEntries then
				execSec:Text("_G config detected — edit it on the left.")
			end
			execSec:Spacing()
		else
			execSec:Text("No script selected.")
			execSec:Spacing()
		end

		execSec:Button("Execute Script", 210, 34, function()
			executeWithTracking(chosen, gEntries, cfgPrefix)
		end)

	elseif mainNav.page == 1 then
		-- RECENTS PAGE
		local recentSec = tab:Section("Recently Executed", "Left")
		
		local recentNames = {}
		for _, recent in ipairs(recents) do
			table.insert(recentNames, wrapName(recent.name or ""))
		end
		
		if #recentNames == 0 then
			recentNames = {"No recent scripts"}
		end
		
		local recentKey = "recent_pick_" .. uiRefresh .. "_" .. #recents
		recentSec:Combo(recentKey, "History", recentNames, 0)
		
		local recentIdx = (UI.GetValue(recentKey) or 0) + 1
		local selectedRecent = recents[recentIdx]
		
		if selectedRecent then
			local recentDetails = tab:Section("Details", "Right")
			recentDetails:Text("Name")
			recentDetails:Text(wrapName(selectedRecent.name or "—"))
			recentDetails:Spacing()
			recentDetails:Text("Creator")
			recentDetails:Text(selectedRecent.uploader or "Unknown")
			recentDetails:Spacing()
			recentDetails:Text("Game")
			recentDetails:Text(wrapName(selectedRecent.game or "Unknown"))
			recentDetails:Spacing()
			
			recentDetails:Button("Execute Again", 210, 34, function()
				local recentGEntries = selectedRecent.script and parseGlobals(selectedRecent.script) or nil
				local recentCfgPrefix = (selectedRecent.name or ""):gsub("[^%w]", "_")
				executeWithTracking(selectedRecent, recentGEntries, recentCfgPrefix)
			end)
		end
	end
end)

